<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<main class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 mb-0"><%= hasRole('pelanggan') ? 'Tagihan Saya' : 'Data Tagihan' %></h1>
  </div>
  <%- include('../partials/flash') %>
  <%- include('../shared/searchFilter', { action: '/tagihan', showStatus: true, query, statusOptions: ['belum_bayar', 'lunas'] }) %>
  <div class="card shadow-sm border-0 app-card">
    <% if (!data.length && hasRole('pelanggan')) { %>
      <div class="card-body">
        <div class="payment-detail-box">
          <span>Status Tagihan</span>
          <strong>Belum ada tagihan. Tagihan pertama akan dibuat setelah pemasangan selesai oleh teknisi.</strong>
        </div>
      </div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-hover app-table mb-0">
          <thead class="table-light"><tr><th>Pelanggan</th><th>Paket</th><th>Tanggal</th><th>Jumlah</th><th>Status</th><th>Keterangan</th></tr></thead>
          <tbody>
            <% data.forEach((item) => { %>
              <tr>
                <td><%= item.nama_pelanggan %></td>
                <td><%= item.nama_paket %></td>
                <td><%= new Date(item.tanggal_tagihan).toLocaleDateString('id-ID') %></td>
                <td>Rp <%= Number(item.jumlah_tagihan).toLocaleString('id-ID') %></td>
                <td><span class="badge <%= item.status_tagihan === 'lunas' ? 'bg-success' : 'bg-warning text-dark' %>"><%= item.status_tagihan %></span></td>
                <td>
                  <% if (hasRole('admin')) { %>
                    <span class="small text-muted"><%= item.status_tagihan === 'lunas' ? 'Pelanggan sudah bayar' : 'Pelanggan belum bayar' %></span>
                  <% } else { %>
                    <span class="small text-muted">Tagihan dibuat setelah tugas pemasangan selesai.</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
  <div class="mt-3"><%- include('../partials/pagination', { pagination, query }) %></div>
</main>
<%- include('../partials/footer') %>
