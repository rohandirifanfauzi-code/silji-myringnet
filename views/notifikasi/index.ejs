<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<main class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 mb-0">Notifikasi</h1>
  </div>
  <%- include('../shared/searchFilter', { action: '/notifikasi', showStatus: true, query, statusOptions: ['BELUM', 'SUDAH'] }) %>
  <div class="card shadow-sm border-0 app-card">
    <div class="list-group list-group-flush">
      <% data.forEach((item) => { %>
        <div class="list-group-item d-flex justify-content-between align-items-start gap-3">
          <div>
            <div class="fw-semibold"><%= item.pesan %></div>
            <small class="text-muted"><%= new Date(item.tanggal).toLocaleString('id-ID') %></small>
          </div>
          <div>
            <span class="badge <%= item.status_baca === 'SUDAH' ? 'bg-success' : 'bg-warning text-dark' %>"><%= item.status_baca %></span>
            <% if (item.status_baca !== 'SUDAH') { %>
              <form action="/notifikasi/<%= item.id %>/read" method="post" class="mt-2">
                <button class="btn btn-sm btn-outline-primary">Tandai Dibaca</button>
              </form>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
  <div class="mt-3"><%- include('../partials/pagination', { pagination, query }) %></div>
</main>
<%- include('../partials/footer') %>
