<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<main class="container py-4">
  <div class="card shadow-sm border-0 app-card">
    <div class="card-body">
      <h1 class="h4 mb-4"><%= item ? 'Edit' : 'Tambah' %> Pelanggan</h1>
      <form method="post" action="<%= item ? `/pelanggan/${item.id}?_method=PUT` : '/pelanggan' %>" class="row g-3">
        <div class="col-md-6"><label class="form-label">Nama</label><input class="form-control" name="nama" value="<%= item?.nama || '' %>" required /></div>
        <div class="col-md-6"><label class="form-label">No HP</label><input class="form-control" name="no_hp" value="<%= item?.no_hp || '' %>" required /></div>
        <div class="col-md-6">
          <label class="form-label">Paket</label>
          <select class="form-select" name="id_paket" required>
            <option value="">Pilih paket</option>
            <% paket.forEach((row) => { %>
              <option value="<%= row.id %>" <%= String(item?.id_paket || '') === String(row.id) ? 'selected' : '' %>><%= row.nama_paket %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-12"><label class="form-label">Alamat</label><textarea class="form-control" name="alamat" rows="3" required><%= item?.alamat || '' %></textarea></div>
        <div class="col-md-6">
          <label class="form-label">Info Akun</label>
          <input class="form-control" value="<%= item?.username || 'Akan dibuat otomatis setelah disimpan' %>" disabled />
        </div>
        <div class="col-12 d-flex gap-2">
          <button class="btn btn-primary">Simpan</button>
          <a href="/pelanggan" class="btn btn-secondary">Kembali</a>
        </div>
      </form>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
