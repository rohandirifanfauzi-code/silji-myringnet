<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<main class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 mb-0"><%= hasRole('pelanggan') ? 'Profil Pelanggan' : 'Data Pelanggan' %></h1>
    <% if (hasRole('admin')) { %>
      <a href="/pelanggan/create" class="btn btn-primary">Tambah Pelanggan</a>
    <% } %>
  </div>
  <%- include('../partials/flash') %>
  <% if (!hasRole('pelanggan')) { %>
    <%- include('../shared/searchFilter', { action: '/pelanggan', showStatus: false, query }) %>
  <% } %>
  <div class="card shadow-sm border-0 app-card">
    <div class="table-responsive">
      <table class="table table-hover app-table mb-0">
        <thead class="table-light"><tr><th>Nama</th><th>Username</th><th>No HP</th><th>Paket</th><th>Tanggal Daftar</th><th><%= hasRole('admin') ? 'Aksi' : 'Info Akun' %></th></tr></thead>
        <tbody>
          <% data.forEach((item) => { %>
            <tr>
              <td><%= item.nama %></td>
              <td><%= item.username %></td>
              <td><%= item.no_hp %></td>
              <td><%= item.nama_paket %></td>
              <td><%= new Date(item.tanggal_daftar).toLocaleDateString('id-ID') %></td>
              <td>
                <% if (hasRole('admin')) { %>
                  <div class="d-flex gap-2">
                    <a href="/pelanggan/<%= item.id %>/edit" class="btn btn-sm btn-outline-primary">Edit</a>
                    <form action="/pelanggan/<%= item.id %>/delete" method="post">
                      <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Hapus data?')">Hapus</button>
                    </form>
                  </div>
                <% } else { %>
                  <span class="text-muted small">Username mengikuti akun yang dibuat admin</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <% if (!hasRole('pelanggan')) { %>
    <div class="mt-3">
      <%- include('../partials/pagination', { pagination, query }) %>
    </div>
  <% } %>
</main>
<%- include('../partials/footer') %>
