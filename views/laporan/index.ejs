<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<main class="container py-4">
  <div class="report-header mb-4">
    <div>
      <span class="section-heading__eyebrow">SILJI MyRingNet</span>
      <h1 class="h4 mb-1">Laporan Perusahaan</h1>
      <p class="text-muted mb-0">Tanggal cetak: <%= printedAt.toLocaleString('id-ID') %></p>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-3"><div class="stat-card stat-card--cyan"><span>Total Pelanggan</span><strong><%= reports.pelanggan.total %></strong><small>Aktif: <%= reports.pelanggan.aktif %></small></div></div>
    <div class="col-md-3"><div class="stat-card stat-card--gold"><span>Total Tagihan</span><strong><%= reports.tagihan.total %></strong><small>Belum bayar: <%= reports.tagihan.belumBayar %></small></div></div>
    <div class="col-md-3"><div class="stat-card stat-card--green"><span>Pemasukan</span><strong>Rp <%= Number(reports.pembayaran.totalPemasukan).toLocaleString('id-ID') %></strong><small><%= reports.pembayaran.totalTransaksi %> transaksi</small></div></div>
    <div class="col-md-3"><div class="stat-card stat-card--coral"><span>Keluhan</span><strong><%= reports.keluhan.total %></strong><small>Selesai: <%= reports.keluhan.status.find((row) => row.label === 'selesai')?.total || 0 %></small></div></div>
  </div>

  <div class="row g-4">
    <div class="col-lg-6">
      <section class="card app-card border-0 shadow-sm report-card h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
            <div>
              <span class="section-heading__eyebrow">Laporan Pelanggan</span>
              <h2 class="h5 mb-1">Pertumbuhan Pelanggan</h2>
              <p class="text-muted small mb-0">Total, pelanggan baru per bulan, dan pelanggan aktif.</p>
            </div>
            <div class="d-flex flex-wrap gap-2 justify-content-end">
              <a href="/laporan/pdf/pelanggan" class="btn btn-danger btn-sm">Download PDF</a>
              <a href="/laporan/excel/pelanggan" class="btn btn-success btn-sm">Download Excel</a>
            </div>
          </div>
          <div class="report-summary-grid mb-3">
            <div><span>Total</span><strong><%= reports.pelanggan.total %></strong></div>
            <div><span>Aktif</span><strong><%= reports.pelanggan.aktif %></strong></div>
            <div><span>Baru Bulan Ini</span><strong><%= reports.pelanggan.baruBulanIni %></strong></div>
          </div>
          <div class="table-responsive">
            <table class="table app-table report-table mb-0">
              <thead><tr><th>Bulan</th><th class="text-end">Pelanggan Baru</th></tr></thead>
              <tbody>
                <% reports.pelanggan.bulanan.forEach((row) => { %>
                  <tr><td><%= row.label %></td><td class="text-end"><%= row.total %></td></tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <p class="report-note mb-0 mt-3">Keterangan: pelanggan aktif dihitung dari seluruh pelanggan terdaftar.</p>
        </div>
      </section>
    </div>

    <div class="col-lg-6">
      <section class="card app-card border-0 shadow-sm report-card h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
            <div>
              <span class="section-heading__eyebrow">Laporan Tagihan</span>
              <h2 class="h5 mb-1">Status Tagihan</h2>
              <p class="text-muted small mb-0">Total tagihan, belum bayar, lunas, dan nominal.</p>
            </div>
            <div class="d-flex flex-wrap gap-2 justify-content-end">
              <a href="/laporan/pdf/tagihan" class="btn btn-danger btn-sm">Download PDF</a>
              <a href="/laporan/excel/tagihan" class="btn btn-success btn-sm">Download Excel</a>
            </div>
          </div>
          <div class="report-summary-grid mb-3">
            <div><span>Total</span><strong><%= reports.tagihan.total %></strong></div>
            <div><span>Belum Bayar</span><strong><%= reports.tagihan.belumBayar %></strong></div>
            <div><span>Lunas</span><strong><%= reports.tagihan.lunas %></strong></div>
          </div>
          <div class="table-responsive">
            <table class="table app-table report-table mb-0">
              <thead><tr><th>Bulan</th><th class="text-end">Jumlah</th><th class="text-end">Nominal</th></tr></thead>
              <tbody>
                <% reports.tagihan.bulanan.forEach((row) => { %>
                  <tr><td><%= row.label %></td><td class="text-end"><%= row.total %></td><td class="text-end">Rp <%= Number(row.nominal).toLocaleString('id-ID') %></td></tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <p class="report-note mb-0 mt-3">Total nominal: Rp <%= Number(reports.tagihan.nominal).toLocaleString('id-ID') %>.</p>
        </div>
      </section>
    </div>

    <div class="col-lg-6">
      <section class="card app-card border-0 shadow-sm report-card h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
            <div>
              <span class="section-heading__eyebrow">Laporan Pembayaran</span>
              <h2 class="h5 mb-1">Pemasukan dan Metode</h2>
              <p class="text-muted small mb-0">Total pemasukan, metode pembayaran, dan transaksi bulanan.</p>
            </div>
            <div class="d-flex flex-wrap gap-2 justify-content-end">
              <a href="/laporan/pdf/pembayaran" class="btn btn-danger btn-sm">Download PDF</a>
              <a href="/laporan/excel/pembayaran" class="btn btn-success btn-sm">Download Excel</a>
            </div>
          </div>
          <div class="report-summary-grid mb-3">
            <% reports.pembayaran.metode.forEach((row) => { %>
              <div><span><%= row.label.toUpperCase() %></span><strong><%= row.total %></strong><small>Rp <%= Number(row.nominal).toLocaleString('id-ID') %></small></div>
            <% }) %>
          </div>
          <div class="table-responsive">
            <table class="table app-table report-table mb-0">
              <thead><tr><th>Bulan</th><th class="text-end">Transaksi</th><th class="text-end">Pemasukan</th></tr></thead>
              <tbody>
                <% reports.pembayaran.bulanan.forEach((row) => { %>
                  <tr><td><%= row.label %></td><td class="text-end"><%= row.total %></td><td class="text-end">Rp <%= Number(row.nominal).toLocaleString('id-ID') %></td></tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <p class="report-note mb-0 mt-3">Total pemasukan paid: Rp <%= Number(reports.pembayaran.totalPemasukan).toLocaleString('id-ID') %>.</p>
        </div>
      </section>
    </div>

    <div class="col-lg-6">
      <section class="card app-card border-0 shadow-sm report-card h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
            <div>
              <span class="section-heading__eyebrow">Laporan Keluhan</span>
              <h2 class="h5 mb-1">Status Keluhan</h2>
              <p class="text-muted small mb-0">Jumlah keluhan dan status penanganan.</p>
            </div>
            <div class="d-flex flex-wrap gap-2 justify-content-end">
              <a href="/laporan/pdf/keluhan" class="btn btn-danger btn-sm">Download PDF</a>
              <a href="/laporan/excel/keluhan" class="btn btn-success btn-sm">Download Excel</a>
            </div>
          </div>
          <div class="report-summary-grid mb-3">
            <% reports.keluhan.status.forEach((row) => { %>
              <div><span><%= row.label %></span><strong><%= row.total %></strong></div>
            <% }) %>
          </div>
          <div class="table-responsive">
            <table class="table app-table report-table mb-0">
              <thead><tr><th>Bulan</th><th class="text-end">Keluhan</th></tr></thead>
              <tbody>
                <% reports.keluhan.bulanan.forEach((row) => { %>
                  <tr><td><%= row.label %></td><td class="text-end"><%= row.total %></td></tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <p class="report-note mb-0 mt-3">Total keluhan: <%= reports.keluhan.total %>.</p>
        </div>
      </section>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
