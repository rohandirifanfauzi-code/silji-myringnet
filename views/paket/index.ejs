<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<main class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 mb-0">Data Paket</h1>
    <% if (hasRole('admin')) { %>
      <a href="/paket/create" class="btn btn-primary">Tambah Paket</a>
    <% } %>
  </div>
  <%- include('../partials/flash') %>
  <%- include('../shared/searchFilter', { action: '/paket', showStatus: false, query }) %>
  <div class="card shadow-sm border-0 app-card">
    <div class="table-responsive">
      <table class="table table-hover app-table mb-0">
        <thead class="table-light"><tr><th>Nama Paket</th><th>Kecepatan</th><th>Harga</th><th>Deskripsi</th><th><%= hasRole('admin') ? 'Aksi' : 'Keterangan' %></th></tr></thead>
        <tbody>
          <% data.forEach((item) => { %>
            <tr>
              <td><%= item.nama_paket %></td>
              <td><%= item.kecepatan %></td>
              <td>Rp <%= Number(item.harga).toLocaleString('id-ID') %></td>
              <td><%= item.deskripsi %></td>
              <td>
                <% if (hasRole('admin')) { %>
                  <div class="d-flex gap-2">
                    <a href="/paket/<%= item.id %>/edit" class="btn btn-sm btn-outline-primary">Edit</a>
                    <form action="/paket/<%= item.id %>/delete" method="post">
                      <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Hapus data?')">Hapus</button>
                    </form>
                  </div>
                <% } else { %>
                  <span class="small text-muted">Mode baca saja.</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="mt-3"><%- include('../partials/pagination', { pagination, query }) %></div>
</main>
<%- include('../partials/footer') %>
