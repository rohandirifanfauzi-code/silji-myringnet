<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<main class="container py-4">
  <%- include('../partials/flash') %>
  <section class="hero-panel mb-4">
    <div class="hero-panel__content">
      <div>
        <span class="hero-panel__eyebrow">Sistem Informasi Layanan Internet</span>
        <h1 class="hero-panel__title">Operasional MyRingNet dalam satu tampilan yang lebih rapi.</h1>
        <p class="hero-panel__text mb-0">
          <% if (hasRole('admin')) { %>
            Kelola pelanggan, teknisi, tagihan, pembayaran, dan update layanan dari panel admin.
          <% } else if (hasRole('teknisi')) { %>
            Fokus pada tugas hari ini, riwayat pekerjaan, dan notifikasi lapangan yang perlu segera dijadwalkan.
          <% } else { %>
            Pantau tagihan dan pembayaran Anda tanpa fitur operasional yang tidak relevan.
          <% } %>
        </p>
      </div>
      <div class="hero-panel__meta">
        <div><span>Role aktif</span><strong><%= currentUser ? currentUser.role : '-' %></strong></div>
        <div><span>Portal</span><strong>localhost:3000</strong></div>
      </div>
    </div>
  </section>

  <% if (hasRole('admin')) { %>
    <div class="card shadow-sm border-0 app-card">
      <div class="card-body">
        <div class="section-heading mb-3">
          <span class="section-heading__eyebrow">Aktivitas Sistem</span>
          <h2 class="h5 mb-0">5 Notifikasi Terbaru</h2>
        </div>
        <div class="list-group list-group-flush">
          <% notifications.forEach((item) => { %>
            <div class="list-group-item px-0 notification-item">
              <div class="fw-semibold"><%= item.pesan %></div>
              <small class="text-muted"><%= new Date(item.tanggal).toLocaleString('id-ID') %></small>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  <% } %>

  <% if (hasRole('pelanggan') && summary) { %>
    <div class="row g-4 mb-4">
      <div class="col-md-4"><div class="stat-card stat-card--gold"><span>Total Tagihan</span><strong><%= summary.totalTagihan %></strong><small>Seluruh tagihan Anda</small></div></div>
      <div class="col-md-4"><div class="stat-card stat-card--green"><span>Riwayat Bayar</span><strong><%= summary.totalPembayaran %></strong><small>Pembayaran tercatat</small></div></div>
      <div class="col-md-4"><div class="stat-card stat-card--coral"><span>Keluhan Saya</span><strong><%= summary.totalKeluhan %></strong><small>Status layanan Anda</small></div></div>
    </div>
    <div class="card shadow-sm border-0 app-card">
      <div class="card-body">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
          <div>
            <div class="section-heading mb-1">
              <span class="section-heading__eyebrow">Tagihan Terbaru</span>
              <h2 class="h5 mb-0">Ringkasan Tagihan</h2>
            </div>
          </div>
          <a href="https://wa.me/6285797128942" target="_blank" class="btn btn-success">
            <i class="bi bi-whatsapp me-2"></i>Hubungi Customer Service
          </a>
        </div>
        <% if (!customerBills.length) { %>
          <div class="payment-detail-box">
            <span>Status Tagihan</span>
            <strong>Tagihan akan muncul setelah teknisi menyelesaikan pemasangan.</strong>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover app-table mb-0">
              <thead class="table-light"><tr><th>Paket</th><th>Tanggal</th><th>Jumlah</th><th>Status</th></tr></thead>
              <tbody>
                <% customerBills.forEach((item) => { %>
                  <tr>
                    <td><%= item.nama_paket %></td>
                    <td><%= new Date(item.tanggal_tagihan).toLocaleDateString('id-ID') %></td>
                    <td>Rp <%= Number(item.jumlah_tagihan).toLocaleString('id-ID') %></td>
                    <td><span class="badge <%= item.status_tagihan === 'LUNAS' ? 'bg-success' : 'bg-warning text-dark' %>"><%= item.status_tagihan %></span></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  <% } %>

  <% if (hasRole('teknisi')) { %>
    <div class="row g-4">
      <div class="col-lg-7">
        <div class="card shadow-sm border-0 app-card">
          <div class="card-body">
            <div class="section-heading mb-3">
              <span class="section-heading__eyebrow">Agenda Hari Ini</span>
              <h2 class="h5 mb-0">Tugas Teknisi Hari Ini</h2>
            </div>
            <div class="task-stack">
              <% if (!todayTasks.length) { %>
                <div class="text-muted small">Belum ada tugas yang dijadwalkan untuk hari ini.</div>
              <% } %>
              <% todayTasks.forEach((item) => { %>
                <article class="task-card">
                  <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                    <div>
                      <div class="fw-semibold"><%= item.nama_pelanggan %></div>
                      <div class="small text-muted"><%= item.tipe_tugas === 'psb' ? 'Pemasangan baru' : 'Maintenance / keluhan' %></div>
                    </div>
                    <span class="badge <%= item.status === 'SELESAI' ? 'bg-success' : 'bg-info text-dark' %>"><%= item.status %></span>
                  </div>
                  <div class="small mb-2"><strong>Tanggal:</strong> <%= item.tanggal_tugas ? new Date(item.tanggal_tugas).toLocaleDateString('id-ID') : '-' %></div>
                  <div class="small mb-3"><strong>Lokasi:</strong> <%= item.detail_lokasi %></div>
                  <iframe class="map-frame" src="https://www.google.com/maps?q=<%= encodeMapQuery(item.alamat_pelanggan || item.detail_lokasi) %>&output=embed" loading="lazy"></iframe>
                </article>
              <% }) %>
            </div>
          </div>
        </div>
      </div>
      <div class="col-lg-5">
        <div class="card shadow-sm border-0 app-card">
          <div class="card-body">
            <div class="section-heading mb-3">
              <span class="section-heading__eyebrow">Riwayat Lapangan</span>
              <h2 class="h5 mb-0">History Tugas</h2>
            </div>
            <div class="list-group list-group-flush">
              <% if (!taskHistory.length) { %>
                <div class="text-muted small">Belum ada history tugas sebelumnya.</div>
              <% } %>
              <% taskHistory.forEach((item) => { %>
                <div class="list-group-item px-0 notification-item">
                  <div class="fw-semibold"><%= item.nama_pelanggan %></div>
                  <div class="small text-muted"><%= item.tipe_tugas === 'psb' ? 'PSB' : 'Maintenance' %> • <%= item.detail_lokasi %></div>
                  <small class="text-muted">Tanggal tugas: <%= item.tanggal_tugas ? new Date(item.tanggal_tugas).toLocaleDateString('id-ID') : '-' %></small>
                </div>
              <% }) %>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% } %>
</main>
<%- include('../partials/footer') %>
