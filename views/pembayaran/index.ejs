<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<main class="container py-4">
  <div class="row g-4">
    <% if (hasRole('admin', 'pelanggan')) { %>
      <div class="col-lg-4">
        <div class="card shadow-sm border-0 app-card">
          <div class="card-body">
            <h1 class="h4 mb-3"><%= hasRole('pelanggan') ? 'Bayar Tagihan Saya' : 'Input Pembayaran' %></h1>
            <form method="post" action="/pembayaran" class="vstack gap-3">
              <div>
                <label class="form-label">Tagihan</label>
                <select class="form-select" name="id_tagihan" required>
                  <option value="">Pilih tagihan</option>
                  <% tagihan.forEach((item) => { %>
                    <option value="<%= item.id %>"><%= item.nama_pelanggan %> - Rp <%= Number(item.jumlah_tagihan).toLocaleString('id-ID') %></option>
                  <% }) %>
                </select>
              </div>
              <div><label class="form-label">Metode Pembayaran</label><input class="form-control" name="metode_pembayaran" placeholder="Transfer / Cash / VA" required /></div>
              <div><label class="form-label">Jumlah Bayar</label><input type="number" class="form-control" name="jumlah_bayar" required /></div>
              <div><label class="form-label">Tanggal Bayar</label><input type="date" class="form-control" name="tanggal_bayar" required /></div>
              <button class="btn btn-primary">Simpan Pembayaran</button>
            </form>
          </div>
        </div>
      </div>
    <% } %>
    <div class="<%= hasRole('admin', 'pelanggan') ? 'col-lg-8' : 'col-lg-12' %>">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h4 mb-0"><%= hasRole('manajemen') ? 'Rekap Pembayaran' : 'Riwayat Pembayaran' %></h2>
      </div>
      <%- include('../partials/flash') %>
      <%- include('../shared/searchFilter', { action: '/pembayaran', showStatus: false, query }) %>
      <div class="card shadow-sm border-0 app-card">
        <div class="table-responsive">
          <table class="table table-hover app-table mb-0">
            <thead class="table-light"><tr><th>Pelanggan</th><th>Metode</th><th>Jumlah</th><th>Tanggal</th><th>Status Tagihan</th><th><%= hasRole('admin') ? 'Aksi' : 'Catatan' %></th></tr></thead>
            <tbody>
              <% data.forEach((item) => { %>
                <tr>
                  <td><%= item.nama_pelanggan %></td>
                  <td><%= item.metode_pembayaran %></td>
                  <td>Rp <%= Number(item.jumlah_bayar).toLocaleString('id-ID') %></td>
                  <td><%= new Date(item.tanggal_bayar).toLocaleDateString('id-ID') %></td>
                  <td><span class="badge bg-success"><%= item.status_tagihan %></span></td>
                  <td>
                    <% if (hasRole('admin')) { %>
                      <form action="/pembayaran/<%= item.id %>/delete" method="post">
                        <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Hapus pembayaran?')">Hapus</button>
                      </form>
                    <% } else { %>
                      <span class="small text-muted">Pembayaran tercatat di sistem.</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <div class="mt-3"><%- include('../partials/pagination', { pagination, query }) %></div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
