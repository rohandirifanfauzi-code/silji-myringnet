<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<main class="container py-4">
  <%- include('../partials/flash') %>
  <div class="row g-4">
    <% if (hasRole('admin', 'pelanggan')) { %>
      <div class="col-md-6">
        <div class="card shadow-sm border-0 app-card">
          <div class="card-body">
            <h1 class="h4 mb-3"><%= hasRole('pelanggan') ? 'Bayar Tagihan Saya' : 'Input Pembayaran' %></h1>
            <% if (hasRole('pelanggan') && activeBill) { %>
              <div class="payment-detail-box mb-3">
                <span>Tagihan Aktif</span>
                <strong>Rp <%= Number(activeBill.jumlah_tagihan).toLocaleString('id-ID') %></strong>
                <small><%= activeBill.nama_paket %> - <%= activeBill.status_tagihan %></small>
              </div>
            <% } %>
            <% if (hasRole('pelanggan') && !activeBill) { %>
              <div class="payment-detail-box">
                <span>Status Tagihan</span>
                <strong>Tidak ada tagihan aktif.</strong>
                <small>Tagihan akan muncul otomatis dari sistem billing.</small>
              </div>
            <% } else { %>
              <form method="post" action="/pembayaran/prepare" class="vstack gap-3 payment-method-form">
                <%- include('../partials/csrf') %>
                <% if (hasRole('admin')) { %>
                  <div>
                    <label class="form-label">Tagihan</label>
                    <select class="form-select" name="id_tagihan" id="paymentBillSelect" required>
                      <option value="">Pilih tagihan</option>
                      <% tagihan.forEach((item) => { %>
                        <option value="<%= item.id %>" data-amount="<%= Number(item.jumlah_tagihan) %>"><%= item.nama_pelanggan %> - Rp <%= Number(item.jumlah_tagihan).toLocaleString('id-ID') %></option>
                      <% }) %>
                    </select>
                  </div>
                <% } else { %>
                  <input type="hidden" name="id_tagihan" value="<%= activeBill.id %>" />
                <% } %>
              <div>
                <label class="form-label">Metode Pembayaran</label>
                <select class="form-select" name="metode" id="paymentMethodSelect" required>
                  <option value="">Pilih metode</option>
                  <option value="qris" <%= paymentDraft?.metode === 'qris' ? 'selected' : '' %>>QRIS</option>
                  <option value="va" <%= paymentDraft?.metode === 'va' ? 'selected' : '' %>>Virtual Account</option>
                  <option value="cash" <%= query.metode === 'cash' ? 'selected' : '' %>>Cash</option>
                </select>
              </div>
              <button class="btn btn-primary">Lanjutkan</button>
            </form>
            <% } %>
          </div>
        </div>
      </div>
    <% } %>
    <div class="<%= hasRole('admin', 'pelanggan') ? 'col-md-6' : 'col-lg-12' %>">
      <div class="card shadow-sm border-0 app-card payment-output-card mb-4">
        <div class="card-body">
          <div class="section-heading mb-3">
            <span class="section-heading__eyebrow">Output Pembayaran</span>
            <h2 class="h5 mb-0">Instruksi Dinamis</h2>
          </div>
          <% if (paymentDraft?.metode === 'qris') { %>
            <div class="payment-output payment-output--center">
              <img src="<%= paymentDraft.qrCode %>" alt="QRIS" class="payment-qr-image" />
              <h3 class="h6 mt-3 mb-1">Scan QRIS untuk simulasi pembayaran</h3>
              <p class="text-muted mb-3"><%= paymentDraft.pelanggan %> • Rp <%= Number(paymentDraft.jumlah).toLocaleString('id-ID') %></p>
              <div class="payment-detail-box w-100 text-start">
                <span>Payment Reference</span>
                <strong><%= paymentDraft.paymentReference %></strong>
              </div>
              <form method="post" action="/pembayaran" class="w-100">
                <%- include('../partials/csrf') %>
                <input type="hidden" name="payment_id" value="<%= paymentDraft.paymentId %>" />
                <input type="hidden" name="metode" value="qris" />
                <button class="btn btn-primary w-100">Simulasikan Pembayaran QRIS Berhasil</button>
              </form>
              <form method="post" action="/payment/callback" class="w-100">
                <input type="hidden" name="payment_reference" value="<%= paymentDraft.paymentReference %>" />
                <input type="hidden" name="status" value="paid" />
                <button class="btn btn-outline-primary w-100">Simulasikan Callback Gateway</button>
              </form>
            </div>
          <% } else if (paymentDraft?.metode === 'va') { %>
            <div class="payment-output">
              <div class="payment-detail-box">
                <span>Nomor Virtual Account</span>
                <strong><%= paymentDraft.vaNumber %></strong>
              </div>
              <div class="payment-detail-box">
                <span>Payment Reference</span>
                <strong><%= paymentDraft.paymentReference %></strong>
              </div>
              <div class="payment-detail-box">
                <span>Nominal</span>
                <strong>Rp <%= Number(paymentDraft.jumlah).toLocaleString('id-ID') %></strong>
              </div>
              <p class="text-muted mb-3">Silakan transfer ke nomor VA di atas. Setelah itu klik tombol konfirmasi simulasi pembayaran.</p>
              <form method="post" action="/pembayaran">
                <%- include('../partials/csrf') %>
                <input type="hidden" name="payment_id" value="<%= paymentDraft.paymentId %>" />
                <input type="hidden" name="metode" value="va" />
                <button class="btn btn-primary w-100">Konfirmasi Pembayaran VA</button>
              </form>
              <form method="post" action="/payment/callback" class="mt-2">
                <input type="hidden" name="payment_reference" value="<%= paymentDraft.paymentReference %>" />
                <input type="hidden" name="status" value="paid" />
                <button class="btn btn-outline-primary w-100">Simulasikan Callback Gateway</button>
              </form>
            </div>
          <% } else if (hasRole('admin') && query.metode === 'cash' && query.id_tagihan) { %>
            <div class="payment-output">
              <form method="post" action="/pembayaran" class="vstack gap-3">
                <%- include('../partials/csrf') %>
                <input type="hidden" name="id_tagihan" value="<%= query.id_tagihan %>" />
                <input type="hidden" name="metode" value="cash" />
                <div>
                  <label class="form-label">Jumlah Bayar</label>
                  <input type="number" name="jumlah_bayar" class="form-control" required />
                </div>
                <div>
                  <label class="form-label">Tanggal Bayar</label>
                  <input type="date" name="tanggal_bayar" class="form-control" required />
                </div>
                <button class="btn btn-primary">Simpan Pembayaran Cash</button>
              </form>
            </div>
          <% } else { %>
            <div class="payment-output payment-output--empty">
              <div class="payment-placeholder-icon">Rp</div>
              <h3 class="h6"><%= hasRole('pelanggan') ? 'Pilih metode pembayaran' : 'Pilih tagihan dan metode pembayaran' %></h3>
              <p class="text-muted mb-0">QRIS akan menampilkan QR code, Virtual Account akan membuat nomor VA simulasi, dan Cash akan mencatat pembayaran sesuai tagihan aktif.</p>
            </div>
          <% } %>
        </div>
      </div>

      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h4 mb-0">Riwayat Pembayaran</h2>
      </div>
      <%- include('../shared/searchFilter', { action: '/pembayaran', showStatus: false, query }) %>
      <div class="card shadow-sm border-0 app-card">
        <div class="table-responsive">
          <table class="table table-hover app-table mb-0">
            <thead class="table-light"><tr><th>Pelanggan</th><th>Metode</th><th>VA / Ref</th><th>Jumlah</th><th>Status Bayar</th><th>Status Tagihan</th><th><%= hasRole('admin') ? 'Aksi' : 'Catatan' %></th></tr></thead>
            <tbody>
              <% data.forEach((item) => { %>
                <tr>
                  <td><%= item.nama_pelanggan %></td>
                  <td><span class="text-uppercase"><%= item.metode %></span></td>
                  <td><%= item.va_number || '-' %></td>
                  <td>Rp <%= Number(item.jumlah_bayar).toLocaleString('id-ID') %></td>
                  <td><span class="badge <%= item.status === 'paid' ? 'bg-success' : 'bg-warning text-dark' %>"><%= item.status %></span></td>
                  <td><span class="badge <%= item.status_tagihan === 'lunas' ? 'bg-success' : 'bg-warning text-dark' %>"><%= item.status_tagihan %></span></td>
                  <td>
                    <% if (hasRole('admin')) { %>
                      <form action="/pembayaran/<%= item.id %>/delete" method="post">
                        <%- include('../partials/csrf') %>
                        <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Hapus pembayaran?')">Hapus</button>
                      </form>
                    <% } else { %>
                      <span class="small text-muted">Pembayaran tercatat di sistem.</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <div class="mt-3"><%- include('../partials/pagination', { pagination, query }) %></div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
