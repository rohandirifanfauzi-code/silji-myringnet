<% if (pagination && pagination.totalPages > 1) { %>
  <nav aria-label="pagination">
    <ul class="pagination">
      <% for (let page = 1; page <= pagination.totalPages; page += 1) { %>
        <li class="page-item <%= pagination.page === page ? 'active' : '' %>">
          <a
            class="page-link"
            href="?page=<%= page %>&limit=<%= pagination.limit %>&search=<%= query.search || '' %>&status=<%= query.status || '' %>"
          ><%= page %></a>
        </li>
      <% } %>
    </ul>
  </nav>
<% } %>
