<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<main class="container py-4">
  <h1 class="h4 mb-3">Audit Log</h1>
  <%- include('../shared/searchFilter', { action: '/audit', showStatus: false, query }) %>
  <div class="card shadow-sm border-0 app-card">
    <div class="table-responsive">
      <table class="table table-hover app-table mb-0">
        <thead><tr><th>Waktu</th><th>User</th><th>Aksi</th><th>Tabel</th><th>Deskripsi</th></tr></thead>
        <tbody>
          <% data.forEach((item) => { %>
            <tr>
              <td><%= new Date(item.created_at).toLocaleString('id-ID') %></td>
              <td><%= item.username || '-' %></td>
              <td><%= item.aksi %></td>
              <td><%= item.tabel %></td>
              <td><%= item.deskripsi || '-' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="mt-3"><%- include('../partials/pagination', { pagination, query }) %></div>
</main>
<%- include('../partials/footer') %>
