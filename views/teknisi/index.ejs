<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<main class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 mb-0">Data Teknisi</h1>
    <% if (hasRole('admin')) { %>
      <a href="/teknisi/create" class="btn btn-primary">Tambah Teknisi</a>
    <% } %>
  </div>
  <%- include('../partials/flash') %>
  <%- include('../shared/searchFilter', { action: '/teknisi', showStatus: true, query, statusOptions: ['AKTIF', 'CUTI', 'NONAKTIF'] }) %>
  <div class="card shadow-sm border-0 app-card">
    <div class="table-responsive">
      <table class="table table-hover app-table mb-0">
        <thead class="table-light"><tr><th>Nama</th><th>Username</th><th>No HP</th><th>Status</th><th><%= hasRole('admin') ? 'Aksi' : 'Keterangan' %></th></tr></thead>
        <tbody>
          <% data.forEach((item) => { %>
            <tr>
              <td><%= item.nama %></td>
              <td><%= item.username %></td>
              <td><%= item.no_hp %></td>
              <td><span class="badge bg-secondary"><%= item.status %></span></td>
              <td>
                <% if (hasRole('admin')) { %>
                  <div class="d-flex gap-2">
                    <a href="/teknisi/<%= item.id %>/edit" class="btn btn-sm btn-outline-primary">Edit</a>
                    <form action="/teknisi/<%= item.id %>/delete" method="post">
                      <%- include('../partials/csrf') %>
                      <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Hapus data?')">Hapus</button>
                    </form>
                  </div>
                <% } else { %>
                  <span class="small text-muted">Monitoring ketersediaan teknisi</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="mt-3"><%- include('../partials/pagination', { pagination, query }) %></div>
</main>
<%- include('../partials/footer') %>
